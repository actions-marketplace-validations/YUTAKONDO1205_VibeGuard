{
  "name": "vibeguard-chrome",
  "displayName": "VibeGuard",
  "description": "Security diagnostics for AI-generated code, in any browser tab.",
  "version": "0.1.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node build.mjs && node copy-static.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vibeguard/analyzer-core": "0.1.3",
    "@vibeguard/findings-schema": "0.1.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
